class Clawlegion < Formula
  desc "ClawLegion Multi-Agent System CLI"
  homepage "https://github.com/clawlegion/clawlegion"
  license "MIT"
  version "{{VERSION}}"

  on_macos do
    if Hardware::CPU.intel?
      url "{{MACOS_X86_64_URL}}"
      sha256 "{{MACOS_X86_64_SHA256}}"
    end
    if Hardware::CPU.arm?
      url "{{MACOS_ARM64_URL}}"
      sha256 "{{MACOS_ARM64_SHA256}}"
    end
  end

  def install
    bin.install "clawlegion"
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/clawlegion --version")
  end
end
