app-id: io.clawlegion.ClawLegion
runtime: org.freedesktop.Platform
runtime-version: "24.08"
sdk: org.freedesktop.Sdk
command: clawlegion
finish-args:
  - --share=network

modules:
  - name: clawlegion
    buildsystem: simple
    build-commands:
      - install -Dm755 clawlegion /app/bin/clawlegion
      - install -Dm644 LICENSE /app/share/licenses/clawlegion/LICENSE
    sources:
      - type: archive
        url: {{ARCHIVE_URL}}
        sha256: {{ARCHIVE_SHA256}}
