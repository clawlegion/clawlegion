# Core runtime
CLAWLEGION_ENV=demo
CLAWLEGION_LOG_LEVEL=info
CLAWLEGION_CONFIG=clawlegion.toml
CLAWLEGION_ORG_CONFIG=config/org.toml

# API
CLAWLEGION_API_HOST=127.0.0.1
CLAWLEGION_API_PORT=8080
CLAWLEGION_WEB_ORIGIN=http://127.0.0.1:3000

# Security
CLAWLEGION_PLUGIN_MODE=dev
CLAWLEGION_PLUGIN_PUBLIC_KEY=
CLAWLEGION_PLUGIN_SIGNING_REQUIRED=false

# LLM/executor placeholders
CLAWLEGION_LLM_PROVIDER=mock
CLAWLEGION_LLM_API_KEY=
CLAWLEGION_EXECUTOR=mock

